{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "durable-graphql",
  "main": "src/index.ts",
  "compatibility_date": "2026-02-20",
  "compatibility_flags": ["nodejs_compat"],
  "rules": [
    {
      "type": "Text",
      "globs": ["**/*.sql"],
      "fallthrough": false
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "GRAPHQL_DO",
        "class_name": "GraphQLDurableObject"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["GraphQLDurableObject"]
    }
  ]
}
